generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Building {
  id          String   @id @default(cuid())
  name        String
  address     String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  floors Floor[]

  @@map("buildings")
}

model Floor {
  id         String   @id @default(cuid())
  buildingId String
  level      String                     // ← String not Int for SQLite ("G", "1", "2")
  name       String
  svgData    String?                    // ← removed @db.Text (not supported in SQLite)
  gridData   String?                    // ← Json → String for SQLite
  widthM     Float?
  heightM    Float?
  gridCols   Int?
  gridRows   Int?
  scaleX     Float?   @default(1)
  scaleY     Float?   @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  building Building @relation(fields: [buildingId], references: [id])
  rooms    Room[]
  nodes    Node[]

  @@unique([buildingId, level])
  @@index([buildingId])
  @@map("floors")
}

model Room {
  id           String   @id @default(cuid())
  floorId      String
  code         String   @unique
  name         String
  type         String                   // ← enum → String for SQLite
  capacity     Int?
  gridX        Int      @default(0)
  gridY        Int      @default(0)
  gridW        Int      @default(10)
  gridH        Int      @default(10)
  centreX      Float    @default(0)
  centreY      Float    @default(0)
  qrCode       String?  @unique
  description  String?
  isAccessible Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  floor        Floor        @relation(fields: [floorId], references: [id])
  nodes        Node[]
  fromSessions NavSession[] @relation("FromRoom")
  toSessions   NavSession[] @relation("ToRoom")

  @@index([floorId])
  @@index([type])
  @@index([qrCode])
  @@map("rooms")
}

model Node {
  id        String   @id @default(cuid())
  floorId   String
  roomId    String?
  gridX     Int
  gridY     Int
  realX     Float
  realY     Float
  type      String   @default("WAYPOINT") // ← enum → String for SQLite
  label     String?
  createdAt DateTime @default(now())

  floor     Floor  @relation(fields: [floorId], references: [id])
  room      Room?  @relation(fields: [roomId], references: [id])
  edgesFrom Edge[] @relation("EdgeFrom")
  edgesTo   Edge[] @relation("EdgeTo")

  @@index([floorId])
  @@index([roomId])
  @@index([gridX, gridY])
  @@map("nodes")
}

model Edge {
  id              String  @id @default(cuid())
  fromNodeId      String
  toNodeId        String
  weight          Float
  isBidirectional Boolean @default(true)
  isAccessible    Boolean @default(true)
  createdAt       DateTime @default(now())

  fromNode Node @relation("EdgeFrom", fields: [fromNodeId], references: [id])
  toNode   Node @relation("EdgeTo", fields: [toNodeId], references: [id])

  @@unique([fromNodeId, toNodeId])
  @@index([fromNodeId])
  @@index([toNodeId])
  @@map("edges")
}

model NavSession {
  id         String   @id @default(cuid())
  fromRoomId String
  toRoomId   String
  path       String?
  distance   Float?
  duration   Float?
  createdAt  DateTime @default(now())

  fromRoom Room @relation("FromRoom", fields: [fromRoomId], references: [id])
  toRoom   Room @relation("ToRoom", fields: [toRoomId], references: [id])

  @@index([fromRoomId])
  @@index([toRoomId])
  @@map("nav_sessions")
}