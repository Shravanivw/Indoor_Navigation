// Prisma Schema — Indoor Navigation System
// Database: SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── BUILDING ────────────────────────────────────────────────────────────────

model Building {
  id          String   @id @default(cuid())
  name        String
  address     String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  floors Floor[]

  @@map("buildings")
}

// ─── FLOOR ───────────────────────────────────────────────────────────────────

model Floor {
  id         String   @id @default(cuid())
  buildingId String
  level      Int                        // 0 = Ground, 1 = First, -1 = Basement
  name       String                     // "Ground Floor", "First Floor"
  svgData    String?                    // Raw SVG of the floor plan
  gridData   String?                    // 2D walkability grid stored as JSON string
  widthM     Float?                     // Real-world width in metres
  heightM    Float?                     // Real-world height in metres
  gridCols   Int?                       // Grid columns count
  gridRows   Int?                       // Grid rows count
  scaleX     Float?   @default(1)       // pixels per metre X
  scaleY     Float?   @default(1)       // pixels per metre Y
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  building Building @relation(fields: [buildingId], references: [id])
  rooms    Room[]
  nodes    Node[]

  @@unique([buildingId, level])
  @@index([buildingId])
  @@map("floors")
}

// ─── ROOM ────────────────────────────────────────────────────────────────────

model Room {
  id          String    @id @default(cuid())
  floorId     String
  code        String    @unique                 // "BOARDROOM", "MR-01", "WC-F1"
  name        String                     // "Boardroom", "Meeting Room 1"
  type        String
  capacity    Int?
  // Bounding box in grid coordinates
  gridX       Int                        // top-left grid column
  gridY       Int                        // top-left grid row
  gridW       Int                        // width in grid cells
  gridH       Int                        // height in grid cells
  // Real-world centre point
  centreX     Float                      // metres from floor origin
  centreY     Float
  // QR code
  qrCode      String?   @unique          // e.g. "LOC-GF-BOARDROOM"
  description String?
  isAccessible Boolean  @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  floor    Floor     @relation(fields: [floorId], references: [id])
  nodes    Node[]                        // entry nodes for this room
  fromSessions NavSession[] @relation("FromRoom")
  toSessions   NavSession[] @relation("ToRoom")

  @@index([floorId])
  @@index([type])
  @@index([qrCode])
  @@map("rooms")
}

// ─── NODE ────────────────────────────────────────────────────────────────────
// A node is a point in the navigation graph (room entry, corridor junction, etc.)

model Node {
  id       String   @id @default(cuid())
  floorId  String
  roomId   String?                        // null if corridor/junction node
  gridX    Int                            // column in walkability grid
  gridY    Int                            // row in walkability grid
  realX    Float                          // metres from floor origin
  realY    Float
  type     String   @default("WAYPOINT")
  label    String?                        // human-readable label
  createdAt DateTime @default(now())

  floor Floor  @relation(fields: [floorId], references: [id])
  room  Room?  @relation(fields: [roomId], references: [id])

  // Edges — both directions stored for fast lookup
  edgesFrom Edge[] @relation("EdgeFrom")
  edgesTo   Edge[] @relation("EdgeTo")

  @@index([floorId])
  @@index([roomId])
  @@index([gridX, gridY])
  @@map("nodes")
}

// ─── EDGE ────────────────────────────────────────────────────────────────────
// Edges connect nodes. Bidirectional edges stored as two records.

model Edge {
  id         String  @id @default(cuid())
  fromNodeId String
  toNodeId   String
  weight     Float                        // distance in metres
  isBidirectional Boolean @default(true)
  isAccessible    Boolean @default(true)  // false = stairs only
  type       String @default("CORRIDOR")

  fromNode Node @relation("EdgeFrom", fields: [fromNodeId], references: [id])
  toNode   Node @relation("EdgeTo",   fields: [toNodeId],   references: [id])

  @@unique([fromNodeId, toNodeId])
  @@index([fromNodeId])
  @@index([toNodeId])
  @@map("edges")
}

// ─── NAVIGATION SESSION ───────────────────────────────────────────────────────

model NavSession {
  id           String   @id @default(cuid())
  fromRoomId   String
  toRoomId     String
  pathNodeIds  String                     // ordered array of node IDs (JSON string)
  pathGridCells String                    // ordered array of {x,y} grid cells (JSON string)
  distanceM    Float                      // total route distance in metres
  estimatedSec Int                        // estimated walk time in seconds
  floorChanges Int      @default(0)
  accessible   Boolean  @default(false)
  createdAt    DateTime @default(now())

  fromRoom Room @relation("FromRoom", fields: [fromRoomId], references: [id])
  toRoom   Room @relation("ToRoom",   fields: [toRoomId],   references: [id])

  @@index([fromRoomId, toRoomId])
  @@index([createdAt])
  @@map("nav_sessions")
}
